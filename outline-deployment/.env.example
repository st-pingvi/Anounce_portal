# Inventory placeholders for operator notes only.
SERVER_IP=<SERVER_IP>
ROOT_USER=<ROOT_USER>
# ROOT_PASSWORD=<ROOT_PASSWORD>

# Domains and TLS
DOMAIN_OUTLINE=<DOMAIN_OUTLINE>
DOMAIN_AUTH=<DOMAIN_AUTH>
TRAEFIK_ACME_EMAIL=<ADMIN_EMAIL>

# Outline application
OUTLINE_VERSION=1.6.1
OUTLINE_SECRET_KEY=<GENERATE_ON_SERVER_64_CHAR_SECRET>
OUTLINE_UTILS_SECRET=<GENERATE_ON_SERVER_64_CHAR_SECRET>
OUTLINE_URL=https://<DOMAIN_OUTLINE>
OUTLINE_PORT=3000
OUTLINE_FORCE_HTTPS=true

# Outline database
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=<SET_ON_SERVER>
OUTLINE_DB_NAME=outline
OUTLINE_DB_USER=outline
OUTLINE_DB_PASSWORD=<SET_ON_SERVER>
AUTHENTIK_DB_NAME=authentik
AUTHENTIK_DB_USER=authentik
AUTHENTIK_DB_PASSWORD=<SET_ON_SERVER>

# Redis
REDIS_URL=redis://redis:6379

# MinIO / S3
MINIO_VERSION=RELEASE.2024-07-16T23-46-41Z
MINIO_ROOT_USER=<SET_ON_SERVER>
MINIO_ROOT_PASSWORD=<SET_ON_SERVER>
S3_BUCKET_NAME=outline-data
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=<SET_ON_SERVER>
AWS_SECRET_ACCESS_KEY=<SET_ON_SERVER>
AWS_S3_UPLOAD_BUCKET_URL=http://minio:9000
AWS_S3_UPLOAD_MAX_SIZE=26214400
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_ACL=private

# Authentik
AUTHENTIK_VERSION=2024.8.3
AUTHENTIK_SECRET_KEY=<GENERATE_ON_SERVER_64_CHAR_SECRET>
AUTHENTIK_BOOTSTRAP_EMAIL=<ADMIN_EMAIL>
AUTHENTIK_BOOTSTRAP_PASSWORD=<SET_ON_SERVER>
AUTHENTIK_ERROR_REPORTING=false

# OIDC for Outline
OIDC_CLIENT_ID=<SET_IN_AUTHENTIK>
OIDC_CLIENT_SECRET=<SET_IN_AUTHENTIK>
OIDC_AUTH_URI=https://<DOMAIN_AUTH>/application/o/authorize/
OIDC_TOKEN_URI=https://<DOMAIN_AUTH>/application/o/token/
OIDC_USERINFO_URI=https://<DOMAIN_AUTH>/application/o/userinfo/
OIDC_DISPLAY_NAME=Authentik
OIDC_SCOPES=openid profile email
OIDC_USERNAME_CLAIM=preferred_username

